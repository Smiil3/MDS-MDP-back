{
  "name": "express-prisma-api-starter",
  "version": "1.0.0",
  "description": "Starter backend API with Express, TypeScript and Prisma",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
